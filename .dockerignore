.dockerignore

# Ignore git, but keep git HEAD and refs to access current commit hash if needed.
.git
!.git/HEAD
!.git/refs

# Common development/test artifacts
/cover/
/doc/
/test/
/tmp/
.elixir_ls
.expert

# Mix artifacts
/_build/
/deps/
*.ez

erl_crash.dump

# Static artifacts - fetched and built inside the Docker image
/priv/static/assets/
/priv/static/cache_manifest.json

# Never send local secrets or eval data into the build context
.env
/eval/
