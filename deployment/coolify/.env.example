# Values to set as secrets in Coolify's "Environment Variables" tab for this
# resource. Not read directly by anything — just a reference list.

# Generate with: openssl rand -base64 48
POSTGRES_PASSWORD=
SECRET_KEY_BASE=

# Public domain Coolify will serve the app on (no scheme), e.g. manfrod.example.com
PHX_HOST=

# Optional integrations - leave blank to disable the feature
ZEN_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
GROQ_API_KEY=
BRAVE_SEARCH_API_KEY=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
